{
  "name": "musicz",
  "version": "1.0.0",
  "description": "MusicZ 盲盒音乐播放器",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.musicz.app",
    "productName": "MusicZ",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "asar": false
  },
  "devDependencies": {
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "NeteaseCloudMusicApi": "^4.31.0"
  }
}
